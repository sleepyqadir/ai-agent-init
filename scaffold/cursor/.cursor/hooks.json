{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "bash .cursor/hooks/session-start.sh"
      }
    ],
    "preToolUse": [
      {
        "command": "python3 .cursor/hooks/security-guard.py",
        "matcher": "Write"
      }
    ],
    "beforeShellExecution": [
      {
        "command": "python3 .cursor/hooks/bash-guard.py",
        "failClosed": false
      }
    ],
    "postToolUse": [
      {
        "command": "bash .cursor/hooks/dependency-audit.sh",
        "matcher": "Write"
      }
    ],
    "stop": [
      {
        "command": "python3 .cursor/hooks/session-close.py"
      }
    ]
  }
}
