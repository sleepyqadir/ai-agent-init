{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "bash .cursor/hooks/session-start.sh"
      }
    ],
    "preToolUse": [
      {
        "command": "python3 .cursor/hooks/security-guard.py",
        "matcher": "Write|Edit"
      }
    ],
    "beforeShellExecution": [
      {
        "command": "python3 .cursor/hooks/bash-guard.py",
        "failClosed": true
      }
    ],
    "postToolUse": [
      {
        "command": "bash .cursor/hooks/dependency-audit.sh",
        "matcher": "Write"
      },
      {
        "command": "bash .cursor/hooks/lint-check.sh",
        "matcher": "Write|Edit"
      }
    ],
    "stop": [
      {
        "command": "python3 .cursor/hooks/pre-stop-verify.py"
      },
      {
        "command": "python3 .cursor/hooks/session-close.py"
      }
    ],
    "afterAgentResponse": [
      {
        "command": "python3 .cursor/hooks/track-tokens.py"
      }
    ]
  }
}
